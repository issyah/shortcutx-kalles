{% doc %}
  @prompt
    5 images with links side by side with 3px spacing
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-links-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-image-links-container-{{ ai_gen_id }} {
    display: flex;
    gap: 3px;
    width: 100%;
  }

  .ai-image-links-item-{{ ai_gen_id }} {
    flex: 1;
    min-width: 0;
  }

  .ai-image-links-link-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    height: 100%;
    position: relative;
    overflow: hidden;
  }

  .ai-image-links-link-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .ai-image-links-link-{{ ai_gen_id }}:hover img {
    transform: scale(1.05);
  }

  .ai-image-links-placeholder-{{ ai_gen_id }} {
    width: 100%;
    padding-bottom: 100%;
    background-color: #f4f4f4;
    position: relative;
  }

  .ai-image-links-placeholder-{{ ai_gen_id }} svg {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 50%;
    height: 50%;
  }

  @media screen and (max-width: 749px) {
    .ai-image-links-container-{{ ai_gen_id }} {
      flex-wrap: wrap;
    }

    .ai-image-links-item-{{ ai_gen_id }} {
      flex: 0 0 calc(50% - 1.5px);
    }

    .ai-image-links-item-{{ ai_gen_id }}:nth-child(5) {
      flex: 0 0 100%;
    }
  }
{% endstyle %}

<div class="ai-image-links-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-image-links-container-{{ ai_gen_id }}">
    {% for i in (1..5) %}
      {% liquid
        assign image_key = 'image_' | append: i
        assign link_key = 'link_' | append: i
        assign image = block.settings[image_key]
        assign link = block.settings[link_key]
      %}
      
      <div class="ai-image-links-item-{{ ai_gen_id }}">
        {% if link != blank %}
          <a href="{{ link }}" class="ai-image-links-link-{{ ai_gen_id }}">
            {% if image %}
              <img
                src="{{ image | image_url: width: 600 }}"
                alt="{{ image.alt | escape }}"
                loading="lazy"
                width="{{ image.width }}"
                height="{{ image.height }}"
              >
            {% else %}
              <div class="ai-image-links-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </a>
        {% else %}
          <div class="ai-image-links-link-{{ ai_gen_id }}">
            {% if image %}
              <img
                src="{{ image | image_url: width: 600 }}"
                alt="{{ image.alt | escape }}"
                loading="lazy"
                width="{{ image.width }}"
                height="{{ image.height }}"
              >
            {% else %}
              <div class="ai-image-links-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</div>

