<!-- sections/hero-irl.liquid -->
{{ 'hero-irl.css' | asset_url | stylesheet_tag }}
{{ 'button-style.css' | asset_url | stylesheet_tag }}
{%- liquid
  assign se = section.settings
  assign image = se.image
  assign overlay_opacity = se.overlay_opacity | divided_by: 100.0
  assign overlay_color = se.overlay_color | color_modify: 'alpha', overlay_opacity
-%}
<div class="t4s-hero-irl" style="--hero-overlay: {{ overlay_color }}; --hero-min-height: {{ se.min_height }}px;">
  <div class="t4s-hero-irl__media">
    {%- if image != blank -%}
      <img
        class="t4s-hero-irl__img lazyloadt4s"
        data-src="{{ image | image_url: width: 1 }}"
        data-widths="[400,600,800,1000,1200,1600,2000]"
        data-optimumx="2"
        data-sizes="auto"
        src="{% render 'img_svg', w: image.width, h: image.height %}"
        width="{{ image.width }}"
        height="{{ image.height }}"
        alt="{{ image.alt | escape }}"
      >
      <span class="lazyloadt4s-loader"></span>
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 't4s-placeholder-svg t4s-hero-irl__placeholder' }}
    {%- endif -%}
    <div class="t4s-hero-irl__overlay"></div>
  </div>

  <div class="t4s-hero-irl__content t4s-container">
    {%- if se.eyebrow != blank -%}
      <p class="t4s-hero-irl__eyebrow">— {{ se.eyebrow | escape }}</p>
    {%- endif -%}

    {%- if se.heading_accent != blank or se.heading_main != blank -%}
      <h1 class="t4s-hero-irl__heading">
        {%- if se.heading_accent != blank -%}<span class="t4s-hero-irl__heading-accent">{{ se.heading_accent | escape }}</span>{%- endif -%}
        {%- if se.heading_main != blank -%}<span class="t4s-hero-irl__heading-main">{{ se.heading_main | escape }}</span>{%- endif -%}
      </h1>
    {%- endif -%}

    {%- if se.subheading != blank -%}
      <p class="t4s-hero-irl__subheading">{{ se.subheading | escape }}</p>
    {%- endif -%}

    {%- if se.description != blank -%}
      <div class="t4s-hero-irl__description">{{ se.description }}</div>
    {%- endif -%}

    {%- if se.button_1_label != blank or se.button_2_label != blank -%}
      <div class="t4s-hero-irl__buttons">
        {%- if se.button_1_label != blank -%}
          <a{% if se.button_1_link != blank %} href="{{ se.button_1_link }}"{% else %} role="link" aria-disabled="true"{% endif %} class="t4s-btn t4s-btn-base t4s-btn-size-large t4s-btn-color-primary t4s-hero-irl__btn">{{ se.button_1_label | escape }}</a>
        {%- endif -%}
        {%- if se.button_2_label != blank -%}
          <a{% if se.button_2_link != blank %} href="{{ se.button_2_link }}"{% else %} role="link" aria-disabled="true"{% endif %} class="t4s-btn t4s-btn-style-link t4s-btn-color-light t4s-btn-size-large t4s-hero-irl__btn t4s-hero-irl__btn--link">
            {{ se.button_2_label | escape }}
            <svg class="t4s-hero-irl__btn-arrow" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true" focusable="false"><path d="M6 1v10M1.5 7L6 11.5 10.5 7" stroke="currentColor" stroke-width="1.5" fill="none"/></svg>
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>

  {%- if se.show_ticker and section.blocks.size > 0 -%}
    <div class="t4s-hero-irl__ticker" style="--ticker-duration: {{ se.ticker_speed }}s;">
      <div class="t4s-hero-irl__ticker-track">
        {%- for i in (1..2) -%}
          <div class="t4s-hero-irl__ticker-set" {% if forloop.first == false %}aria-hidden="true"{% endif %}>
            {%- for block in section.blocks -%}
              <span class="t4s-hero-irl__ticker-item"{% if forloop.parentloop.first %} {{ block.shopify_attributes }}{% endif %}>{{ block.settings.text | escape }}</span>
              <span class="t4s-hero-irl__ticker-sep" aria-hidden="true">⚡</span>
            {%- endfor -%}
          </div>
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Hero IRL",
  "tag": "section",
  "class": "t4s-section t4s-section-all",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "range",
      "id": "min_height",
      "label": "Minimum height",
      "min": 400,
      "max": 900,
      "step": 20,
      "unit": "px",
      "default": 640
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 90,
      "step": 5,
      "unit": "%",
      "default": 35
    },
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Members Only Access"
    },
    {
      "type": "text",
      "id": "heading_accent",
      "label": "Heading line 1 (accent color)",
      "default": "In Real"
    },
    {
      "type": "text",
      "id": "heading_main",
      "label": "Heading line 2",
      "default": "Life."
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Shortcutx • Sport • Community"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>I.R.L is where your subscription becomes a lifestyle. Exclusive workshops, live events and sport collide — all designed to push you further. Members get access. Non-members get left behind.</p>"
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "text",
      "id": "button_1_label",
      "label": "Primary button label",
      "default": "Become a Member"
    },
    {
      "type": "url",
      "id": "button_1_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "button_2_label",
      "label": "Secondary button label",
      "default": "Next Event"
    },
    {
      "type": "url",
      "id": "button_2_link",
      "label": "Secondary button link"
    },
    {
      "type": "header",
      "content": "Scrolling ticker"
    },
    {
      "type": "checkbox",
      "id": "show_ticker",
      "label": "Show scrolling ticker",
      "default": true
    },
    {
      "type": "range",
      "id": "ticker_speed",
      "label": "Ticker scroll duration",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "s",
      "default": 25
    }
  ],
  "blocks": [
    {
      "type": "ticker_item",
      "name": "Ticker item",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Members pay $15"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero IRL",
      "blocks": [
        { "type": "ticker_item", "settings": { "text": "Members pay $15" } },
        { "type": "ticker_item", "settings": { "text": "Boxing with Fash — June 29" } },
        { "type": "ticker_item", "settings": { "text": "Spartans × Shortcutx" } },
        { "type": "ticker_item", "settings": { "text": "Max+ & Flat Tummy Shake included for public" } },
        { "type": "ticker_item", "settings": { "text": "Limited to 15 spots" } }
      ]
    }
  ]
}
{% endschema %}
